{
  "name": "backpack",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22.9.0",
    "npm": ">=10.8.3"
  },
  "workspaces": [
    "packages/*",
    "libs/*"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:Skyscanner/backpack.git"
  },
  "author": "Backpack Design System <backpack@skyscanner.net>",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "check-bpk-dependencies": "node scripts/npm/check-bpk-dependencies.js",
    "check-react-versions": "node scripts/npm/check-react-versions.js",
    "check-pristine": "node scripts/check-pristine-state",
    "clean": "npm run clean:dist && npm run clean:node_modules",
    "clean:dist": "rm -rf dist packages/backpack-web/dist",
    "clean:node_modules": "rm -rf node_modules",
    "danger": "danger ci",
    "figma:generate-config": "node scripts/figma/generate-figma-config.js",
    "figma:generate-icons": "nx run backpack-web:figma-generate-icons",
    "figma:generate": "npm run figma:generate-config && npm run figma:generate-icons",
    "fix-bpk-dependencies": "node scripts/npm/check-bpk-dependencies.js --fix",
    "upgrade-foundations": "node scripts/npm/check-bpk-dependencies.js --fix --upgrade-foundations",
    "jest": "TZ=Etc/UTC jest --coverage",
    "jest:update": "TZ=Etc/UTC jest --updateSnapshot",
    "jest:watch": "TZ=Etc/UTC jest --watch",
    "jest:accessibility": "jest --testRegex accessibility-test",
    "lint": "npm run lint:js && npm run lint:scss",
    "lint:js": "eslint . libs/backpack-storybook-host/.storybook --ext .js,.jsx,.ts,.tsx",
    "lint:js:fix": "eslint . libs/backpack-storybook-host/.storybook --ext .js,.jsx,.ts,.tsx --fix",
    "lint:scss": "nx run backpack-web:lint-scss",
    "lint:scss:fix": "nx run backpack-web:lint-scss-fix",
    "lint-staged": "lint-staged",
    "prettier": "prettier --config .prettierrc --write \"**/*.(js|ts|tsx)\"",
    "start": "npm run build && npm run storybook",
    "storybook": "nx run backpack-storybook-host:serve-storybook -- -p 9001",
    "storybook:dist": "nx run backpack-storybook-host:build-storybook -- -o dist-storybook",
    "tokens:fetch": "tsx token-sync/src/index.ts",
    "tokens:build-css": "tsx token-sync/src/build-css-cli.ts",
    "tokens:sync": "npm run tokens:fetch && npm run tokens:build-css",
    "sassdoc": "nx run backpack-web:sassdoc",
    "test": "npm run lint && npm run check-react-versions && npm run check-bpk-dependencies && npm run jest",
    "typecheck": "tsc && nx run-many -t typecheck",
    "prepare": "husky",
    "percy-test": "percy storybook ./libs/backpack-storybook-host/dist-storybook -i '/Visual\\stest\\s?([a-z]*)?/i'",
    "ts-migrate": "ts-migrate"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.scss": [
      "stylelint --fix",
      "stylelint"
    ]
  },
  "jest": {
    "coverageReporters": [
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    },
    "moduleNameMapper": {
      "^.+\\.scss$": "<rootDir>/scripts/stubs/styleStub.js",
      "^.+\\.(svg|png)$": "<rootDir>/scripts/stubs/fileStub.js",
      "react-transition-group/CSSTransition": "<rootDir>/scripts/stubs/cssTransitionStub.js",
      "@skyscanner/bpk-svgs/dist/svgs/^.+\\.svg$": "<rootDir>/scripts/stubs/fileStub.js",
      "^react($|/.+)": "<rootDir>/node_modules/react$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/scripts/jest/setup.js"
    ],
    "snapshotSerializers": [
      "<rootDir>/scripts/jest/normalizeUseIdSerializer.js"
    ],
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/packages/backpack-adoption-guard/"
    ],
    "testRegex": "(?:packages|token-sync)/.*-test\\.[jt]sx?$",
    "transformIgnorePatterns": [
      "node_modules/(?!bpk|@skyscanner|d3-.*|internmap)"
    ],
    "verbose": true
  },
  "browserslist": [
    "Chrome >= 109",
    "Edge >= 142",
    "Firefox >= 145",
    "Safari >= 16",
    "Samsung >= 29"
  ],
  "devDependencies": {
    "@actions/core": "1.11.1",
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.3",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.2",
    "@babel/plugin-proposal-private-methods": "^7.17.12",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.28.3",
    "@figma/code-connect": "^1.4.3",
    "@figma/rest-api-spec": "^0.37.0",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/react": "22.7.1",
    "@nx/storybook": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@percy/cli": "^1.31.0",
    "@percy/storybook": "^9.1.0",
    "@skyscanner/bpk-foundations-web": "^24.6.0",
    "@skyscanner/bpk-svgs": "^20.11.0",
    "@skyscanner/eslint-config-skyscanner": "^22.6.0",
    "@skyscanner/stylelint-config-skyscanner": "^14.2.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react": "^10.3.5",
    "@storybook/react-webpack5": "^10.3.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/lodash.clamp": "^4.0.9",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/react-transition-group": "^4.4.11",
    "@types/react-window": "^1.8.8",
    "@types/webpack-env": "^1.18.4",
    "autoprefixer": "^10.4.18",
    "babel-loader": "^10.0.0",
    "babel-plugin-inline-react-svg": "^2.0.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-plugin-react-docgen": "^4.2.1",
    "babel-plugin-require-context-hook": "^1.0.0",
    "core-js": "^3.47.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "d3-scale": "^4.0.2",
    "danger": "^13.0.4",
    "danger-plugin-toolbox": "^3.1.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "eslint_d": "^14.3.0",
    "glob": "^13.0.0",
    "gulp": "^5.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-svgmin": "^4.1.0",
    "husky": "^9.1.3",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.2.7",
    "lodash": "^4.18.1",
    "mini-css-extract-plugin": "^2.9.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.7.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.2.0",
    "prop-types": "^15.7.2",
    "raf": "^3.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-svg-loader": "^3.0.1",
    "sass-embedded": "^1.90.0",
    "sass-loader": "^16.0.4",
    "sass-migrator": "^2.5.6",
    "sassdoc": "^2.7.0",
    "storybook": "^10.3.3",
    "style-dictionary": "^5.4.0",
    "style-loader": "^4.0.0",
    "ts-migrate": "^0.1.35",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "webpack": "^5.107.2",
    "wrapper-webpack-plugin": "^2.2.2"
  },
  "overrides": {
    "braces": "3.0.3"
  }
}
