{
  "name": "backpack",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.9.0",
    "pnpm": ">=11.0.8"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Skyscanner/backpack.git"
  },
  "author": "Backpack Design System <backpack@skyscanner.net>",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "check-bpk-dependencies": "node scripts/npm/check-bpk-dependencies.js",
    "check-react-versions": "node scripts/npm/check-react-versions.js",
    "check-pristine": "node scripts/check-pristine-state",
    "clean": "pnpm run clean:dist && pnpm run clean:node_modules",
    "clean:dist": "rm -rf dist packages/backpack-web/dist",
    "clean:node_modules": "rm -rf node_modules",
    "danger": "danger ci",
    "figma:generate-config": "node scripts/figma/generate-figma-config.js",
    "figma:generate-icons": "nx run backpack-web:figma-generate-icons",
    "figma:generate": "pnpm run figma:generate-config && pnpm run figma:generate-icons",
    "fix-bpk-dependencies": "node scripts/npm/check-bpk-dependencies.js --fix",
    "upgrade-foundations": "node scripts/npm/check-bpk-dependencies.js --fix --upgrade-foundations",
    "jest": "TZ=Etc/UTC jest --coverage",
    "jest:update": "TZ=Etc/UTC jest --updateSnapshot",
    "jest:watch": "TZ=Etc/UTC jest --watch",
    "jest:accessibility": "jest --testRegex accessibility-test",
    "lint": "pnpm run lint:js && pnpm run lint:scss",
    "lint:js": "eslint . libs/backpack-storybook-host/.storybook --ext .js,.jsx,.ts,.tsx",
    "lint:js:fix": "eslint . libs/backpack-storybook-host/.storybook --ext .js,.jsx,.ts,.tsx --fix",
    "lint:scss": "nx run backpack-web:lint-scss",
    "lint:scss:fix": "nx run backpack-web:lint-scss-fix",
    "lint-staged": "lint-staged",
    "prettier": "prettier --config .prettierrc --write \"**/*.(js|ts|tsx)\"",
    "start": "pnpm run build && pnpm run storybook",
    "storybook": "nx run backpack-storybook-host:serve-storybook -- -p 9001",
    "storybook:dist": "nx run backpack-storybook-host:build-storybook -- -o dist-storybook",
    "tokens:fetch": "tsx token-sync/src/index.ts",
    "tokens:build-css": "tsx token-sync/src/build-css-cli.ts",
    "tokens:sync": "pnpm run tokens:fetch && pnpm run tokens:build-css",
    "sassdoc": "nx run backpack-web:sassdoc",
    "test": "pnpm run lint && pnpm run check-react-versions && pnpm run check-bpk-dependencies && pnpm run jest",
    "typecheck": "tsc && nx run-many -t typecheck",
    "prepare": "husky",
    "percy-test": "percy storybook ./libs/backpack-storybook-host/dist-storybook -i '/Visual\\stest\\s?([a-z]*)?/i'",
    "ts-migrate": "ts-migrate"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.scss": [
      "stylelint --fix",
      "stylelint"
    ]
  },
  "jest": {
    "coverageReporters": [
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    },
    "moduleNameMapper": {
      "^.+\\.scss$": "<rootDir>/scripts/stubs/styleStub.js",
      "^.+\\.(svg|png)$": "<rootDir>/scripts/stubs/fileStub.js",
      "react-transition-group/CSSTransition": "<rootDir>/scripts/stubs/cssTransitionStub.js",
      "@skyscanner/bpk-svgs/dist/svgs/^.+\\.svg$": "<rootDir>/scripts/stubs/fileStub.js",
      "^react($|/.+)": "<rootDir>/node_modules/react$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/scripts/jest/setup.js"
    ],
    "testEnvironment": "jsdom",
    "testRegex": "(?:packages|token-sync)/.*-test\\.[jt]sx?$",
    "transformIgnorePatterns": [
      "node_modules/(?!(.pnpm|bpk|@skyscanner|d3-.*|internmap))"
    ],
    "verbose": true
  },
  "browserslist": [
    "Chrome >= 109",
    "Edge >= 142",
    "Firefox >= 145",
    "Safari >= 16",
    "Samsung >= 29"
  ],
  "devDependencies": {
    "@babel/cli": "catalog:",
    "@babel/core": "catalog:",
    "@babel/plugin-proposal-class-properties": "catalog:",
    "@babel/plugin-proposal-object-rest-spread": "catalog:",
    "@babel/plugin-proposal-private-methods": "catalog:",
    "@babel/plugin-transform-runtime": "catalog:",
    "@babel/preset-env": "catalog:",
    "@babel/preset-react": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@babel/register": "catalog:",
    "@figma/code-connect": "catalog:",
    "@figma/rest-api-spec": "catalog:",
    "@nx/eslint-plugin": "catalog:",
    "@nx/jest": "catalog:",
    "@nx/js": "catalog:",
    "@nx/react": "catalog:",
    "@nx/storybook": "catalog:",
    "@nx/webpack": "catalog:",
    "@percy/cli": "catalog:",
    "@percy/storybook": "catalog:",
    "@skyscanner/bpk-foundations-web": "catalog:",
    "@skyscanner/bpk-svgs": "catalog:",
    "@skyscanner/eslint-config-skyscanner": "catalog:",
    "@skyscanner/stylelint-config-skyscanner": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-webpack5-compiler-babel": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-webpack5": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/jest": "catalog:",
    "@types/jest-axe": "catalog:",
    "@types/lodash.clamp": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-transition-group": "catalog:",
    "@types/react-window": "catalog:",
    "@types/webpack-env": "catalog:",
    "autoprefixer": "catalog:",
    "babel-loader": "catalog:",
    "babel-plugin-inline-react-svg": "catalog:",
    "babel-plugin-module-resolver": "catalog:",
    "babel-plugin-react-docgen": "catalog:",
    "babel-plugin-require-context-hook": "catalog:",
    "core-js": "catalog:",
    "css-loader": "catalog:",
    "css-minimizer-webpack-plugin": "catalog:",
    "d3-scale": "catalog:",
    "danger": "catalog:",
    "danger-plugin-toolbox": "catalog:",
    "date-fns": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "eslint_d": "catalog:",
    "glob": "catalog:",
    "gulp": "catalog:",
    "gulp-rename": "catalog:",
    "gulp-svgmin": "catalog:",
    "husky": "catalog:",
    "jest": "catalog:",
    "jest-axe": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "lint-staged": "catalog:",
    "lodash": "catalog:",
    "mini-css-extract-plugin": "catalog:",
    "npm-run-all": "catalog:",
    "nx": "catalog:",
    "postcss-flexbugs-fixes": "catalog:",
    "postcss-loader": "catalog:",
    "prop-types": "catalog:",
    "raf": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-svg-loader": "catalog:",
    "sass-embedded": "catalog:",
    "sass-loader": "catalog:",
    "sass-migrator": "catalog:",
    "sassdoc": "catalog:",
    "storybook": "catalog:",
    "style-dictionary": "catalog:",
    "style-loader": "catalog:",
    "ts-migrate": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "webpack": "catalog:",
    "wrapper-webpack-plugin": "catalog:"
  }
}
