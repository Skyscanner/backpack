registry=https://registry.npmjs.org/

# pnpm equivalent of npm's strict-peer-deps
strict-peer-dependencies=true

# Enforce engines field
engine-strict=true

# Hoist tools that expect to be at node_modules root
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*stylelint*
public-hoist-pattern[]=*prettier*
# Hoist all packages to mimic npm behaviour (required during pnpm migration)
shamefully-hoist=true

# Link local workspace packages via symlinks
link-workspace-packages=true
