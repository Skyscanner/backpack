registry=https://registry.npmjs.org/

# pnpm strict peer deps
strict-peer-dependencies=false

# Enforce engines field
engine-strict=true

# TEMPORARY: hoist all packages to reduce migration risk (same approach as web-platform PR #19713)
# Remove this once consumers have updated their imports to be explicit
shamefully-hoist=true

# Link local workspace packages via symlinks
link-workspace-packages=true
