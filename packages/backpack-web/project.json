{
  "name": "backpack-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/backpack-web/src",
  "projectType": "library",
  "tags": ["scope:publishable", "type:design-system"],
  "targets": {
    "generate-svgs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "gulp",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["svgSources"],
      "outputs": [
        "{projectRoot}/src/bpk-component-icon/sm",
        "{projectRoot}/src/bpk-component-icon/lg",
        "{projectRoot}/src/bpk-component-icon/xxxl",
        "{projectRoot}/src/bpk-component-spinner/src/spinners",
        "{projectRoot}/src/bpk-component-flare/src/svgs",
        "{projectRoot}/src/bpk-component-flare/src/__generated__"
      ],
      "cache": true
    },
    "copy-normalize-css": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/scss/copy-normal_css.sh",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "{workspaceRoot}/scripts/scss/copy-normal_css.sh",
        "{workspaceRoot}/node_modules/normalize.css/normalize.css"
      ],
      "outputs": ["{projectRoot}/src/bpk-stylesheets/normalize.scss"],
      "cache": true
    },
    "build-sass": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/scss/styles-prod.js && rm -f packages/backpack-web/src/bpk-stylesheets/index.css",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["copy-normalize-css", "generate-svgs"],
      "inputs": [
        "scss",
        "{workspaceRoot}/scripts/scss/styles-prod.js",
        "{workspaceRoot}/scripts/scss/style-compiler.js"
      ],
      "cache": true
    },
    "build-stylesheets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node build.js",
        "cwd": "{projectRoot}/src/bpk-stylesheets"
      },
      "dependsOn": ["build-sass"],
      "inputs": [
        "{projectRoot}/src/bpk-stylesheets/**/*",
        "{workspaceRoot}/babel.config.js"
      ],
      "cache": true
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rm -rf packages/backpack-web/dist",
          "BABEL_ENV=dev babel packages/backpack-web/src --ignore ./packages/backpack-web/src/bpk-stylesheets --out-dir packages/backpack-web/dist --extensions .ts,.tsx,.js,.jsx --config-file ./babel.config.js",
          "tsc --project tsconfig.declaration.json",
          "node scripts/transpilation/transform-js-scss-css-imports.js",
          "node scripts/transpilation/copy-css.js",
          "node scripts/transpilation/copy-utils.js",
          "cp packages/backpack-web/package.json packages/backpack-web/dist/",
          "cp packages/backpack-web/README.md packages/backpack-web/dist/",
          "node scripts/transpilation/rewrite-exports.js"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["build-stylesheets"],
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/scripts/transpilation/**/*"
      ],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "options": {
        "packageRoot": "{projectRoot}/dist"
      }
    }
  }
}
