    "./bpk-component-grid-toggle": "./src/bpk-component-grid-toggle/index.js",
    "./bpk-component-horizontal-nav": "./src/bpk-component-horizontal-nav/index.js",
    "./bpk-component-icon": "./src/bpk-component-icon/index.tsx",
    "./bpk-component-infinite-scroll": "./src/bpk-component-infinite-scroll/index.js",
    "./bpk-component-loading-button": "./src/bpk-component-loading-button/index.js",
