{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/babel.config.js",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/tsconfig.declaration.json",
      "{workspaceRoot}/.eslintrc",
      "{workspaceRoot}/.stylelintrc.json"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*-test.tsx",
      "!{projectRoot}/**/*-test.ts",
      "!{projectRoot}/**/*-test.js",
      "!{projectRoot}/**/*.stories.tsx",
      "!{projectRoot}/**/accessibility-test.tsx"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "sharedGlobals"],
      "cache": true
    },
    "test": {
      "inputs": ["default", "sharedGlobals"],
      "cache": true
    },
    "lint": {
      "inputs": ["default", "sharedGlobals"],
      "cache": true
    },
    "typecheck": {
      "inputs": ["default", "sharedGlobals"],
      "cache": true
    }
  },
  "cacheDirectory": ".nx/cache",
  "useDaemonProcess": true
}
