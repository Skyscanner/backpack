{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "declaration": true,
    "outDir": "packages/backpack-web/dist",
    "rootDir": "packages/backpack-web/src"
  },
  "include": [
    "packages/backpack-web/src",
    "@types"
  ],
  "exclude": [
    "**/**/*test*",
    "**/**/*stories*",
    "**/**/*.figma.tsx"
  ]
}
