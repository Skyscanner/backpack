{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../../dist/out-tsc/libs/backpack-token-sync",
    "rootDir": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "jest"]
  },
  "exclude": [
    "src/**/*-test.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/__fixtures__/**"
  ],
  "include": ["src/**/*.ts"]
}
